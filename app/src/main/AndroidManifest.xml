<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        Signature-level custom permission for the inter-app IPC demo.
        Both the default and variant APKs DECLARE this permission, so each app
        acts as both the "definer" and the "user" depending on install order.
        protectionLevel="signature" means the OS only grants it to apps signed
        with the same certificate — i.e. the two flavors built from this project.
    -->
    <permission
        android:name="com.example.android.playground.permission.INTER_APP_COMM"
        android:label="Inter-App Communication"
        android:description="@string/app_name"
        android:protectionLevel="signature" />

    <!--
        Both apps must HOLD the permission, not just declare it.
        The OS auto-grants it on install when the signing certificates match.
    -->
    <uses-permission android:name="com.example.android.playground.permission.INTER_APP_COMM" />

    <!--
        Android 11+ (API 30) package visibility: apps cannot see other packages
        unless listed here. Both package IDs must be named so PackageManager
        queries and explicit Intent resolution work regardless of which flavor
        this APK is.
    -->
    <queries>
        <package android:name="com.example.android.playground" />
        <package android:name="com.example.android.playground.variant" />
    </queries>

    <!-- Required for all foreground services -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Required on API 29+ for DATA_SYNC foreground service type -->
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"
        android:minSdkVersion="29" />
    <!-- Required on API 35+ for MEDIA_PROCESSING foreground service type -->
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROCESSING"
        android:minSdkVersion="35" />
    <!-- Required on API 33+ to post upload progress notifications -->
    <uses-permission
        android:name="android.permission.POST_NOTIFICATIONS"
        android:minSdkVersion="33" />
    <!-- Required on API 34+ to schedule User-Initiated Data Transfer Jobs via JobScheduler -->
    <uses-permission
        android:name="android.permission.RUN_USER_INITIATED_JOBS"
        android:minSdkVersion="34" />

    <application
        android:name="com.example.android.playground.AndroidPlaygroundApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_android_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_android_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AndroidPlayground"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="33">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.AndroidPlayground">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            WorkManager's internal SystemForegroundService needs to declare the foreground
            service types used by our workers. We merge into the library's declaration so
            the OS allows the worker to promote itself to a foreground service.
        -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync|mediaProcessing"
            tools:node="merge" />

        <!--
            Disable WorkManager's auto-initialization so we can supply a custom
            HiltWorkerFactory (required for @HiltWorker dependency injection).
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>

</manifest>